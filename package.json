{
  "name": "news-curator",
  "version": "1.0.0",
  "description": "News aggregator with Electron + Vue + TypeScript",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "tsc -p src/main/tsconfig.json && concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && tsc -p src/main/tsconfig.json",
    "preview": "vite preview",
    "start": "electron .",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "news",
    "crawler",
    "electron",
    "vue"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.14.0",
    "cheerio": "^1.2.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.0",
    "concurrently": "^8.2.0",
    "electron": "^31.0.0",
    "electron-is-dev": "^2.0.0",
    "typescript": "^5.3.0",
    "vite": "^6.0.0",
    "vue": "^3.4.0",
    "vue-router": "^4.2.0",
    "vue-tsc": "^3.2.6",
    "wait-on": "^7.2.0"
  }
}
