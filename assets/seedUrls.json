{
  "crawlConfig": {
    "userAgent": "news-curator/1.0 (+https://yourdomain.example)",
    "obeyRobotsTxt": true,
    "sameDomainOnly": true,
    "maxDepth": 2,
    "concurrentRequestsPerDomain": 2,
    "requestDelayMs": 2000,
    "retryCount": 3,
